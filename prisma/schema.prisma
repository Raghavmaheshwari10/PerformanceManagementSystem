// Prisma schema for Performance Management System (hRMS)
// Target: NeonDB (serverless PostgreSQL) via @prisma/adapter-neon
// Generated from 19 Supabase SQL migrations

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

enum UserRole {
  employee
  manager
  hrbp
  admin

  @@map("user_role")
}

enum CycleStatus {
  draft
  kpi_setting
  self_review
  manager_review
  calibrating
  locked
  published

  @@map("cycle_status")
}

enum RatingTier {
  FEE
  EE
  ME
  SME
  BE

  @@map("rating_tier")
}

enum ReviewStatus {
  draft
  submitted

  @@map("review_status")
}

enum GoalType {
  business
  development
  behavior

  @@map("goal_type")
}

enum GoalStatus {
  draft
  submitted
  approved
  rejected
  completed
  closed

  @@map("goal_status")
}

enum NotificationType {
  cycle_kpi_setting_open
  cycle_self_review_open
  cycle_manager_review_open
  cycle_published
  review_submitted
  manager_review_submitted
  admin_message
  review_reminder

  @@map("notification_type")
}

enum NotificationStatus {
  pending
  sent
  failed

  @@map("notification_status")
}

enum FeedbackCategory {
  teamwork
  leadership
  ownership
  communication
  innovation

  @@map("feedback_category")
}

enum FeedbackVisibility {
  private
  recipient_and_manager
  public_team

  @@map("feedback_visibility")
}

enum PeerReviewStatus {
  requested
  accepted
  declined
  submitted

  @@map("peer_review_status")
}

enum AnswerType {
  rating
  text
  mixed

  @@map("answer_type")
}

